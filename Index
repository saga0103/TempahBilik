<!DOCTYPE html>
<html lang="ms">
<head>
  <base target="_top">
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
  <title>Sistem Tempahan Bilik</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
  <?!= include('CSS'); ?>
</head>
<body>

<!-- ===== HEADER ===== -->
<nav class="navbar navbar-dark app-navbar sticky-top">
  <div class="container-fluid px-3">
    <span class="navbar-brand mb-0 fw-semibold">
      🏫 Tempahan Bilik Khas &amp; Makmal
    </span>
  </div>
</nav>

<!-- ===== TAB NAV ===== -->
<ul class="nav nav-pills nav-fill app-tabs sticky-tabs" id="mainTab">
  <li class="nav-item">
    <button class="nav-link active" data-tab="tempah" onclick="papar('tempah')">📝 Tempah</button>
  </li>
  <li class="nav-item">
    <button class="nav-link" data-tab="kalendar" onclick="papar('kalendar')">📅 Kalendar</button>
  </li>
  <li class="nav-item">
    <button class="nav-link" data-tab="admin" onclick="papar('admin')">🛠️ Admin</button>
  </li>
</ul>

<div class="container-fluid px-3 py-3 pb-5">

  <!-- ===== TAB 1: BORANG TEMPAHAN ===== -->
  <div id="view-tempah" class="tab-view">
    <div class="card shadow-sm border-0 rounded-4 mb-3">
      <div class="card-body">
        <h5 class="card-title mb-3 text-teal">Borang Tempahan Bilik</h5>
        <form id="formTempahan">
          <div class="mb-3">
            <label class="form-label">Nama Guru</label>
            <input type="text" class="form-control" id="namaGuru" required placeholder="Cth: Cikgu Ahmad">
          </div>
          <div class="mb-3">
            <label class="form-label">Emel</label>
            <input type="email" class="form-control" id="emelGuru" required placeholder="nama@sekolah.edu.my">
          </div>
          <div class="mb-3">
            <label class="form-label">Pilih Bilik</label>
            <select class="form-select" id="pilihBilik" required>
              <option value="">-- Sila Pilih --</option>
            </select>
          </div>
          <div class="row">
            <div class="col-6 mb-3">
              <label class="form-label">Tarikh</label>
              <input type="date" class="form-control" id="tarikhTempah" required>
            </div>
          </div>
          <div class="row">
            <div class="col-6 mb-3">
              <label class="form-label">Masa Mula</label>
              <input type="time" class="form-control" id="masaMula" required>
            </div>
            <div class="col-6 mb-3">
              <label class="form-label">Masa Tamat</label>
              <input type="time" class="form-control" id="masaTamat" required>
            </div>
          </div>
          <div class="mb-3">
            <label class="form-label">Tujuan</label>
            <textarea class="form-control" id="tujuanTempah" rows="2" required placeholder="Cth: Kelas tambahan Matematik Tingkatan 5"></textarea>
          </div>

          <div id="statusSlot" class="mb-3"></div>

          <button type="submit" class="btn btn-teal w-100 rounded-pill py-2 fw-semibold" id="btnHantar">
            Hantar Tempahan
          </button>
        </form>
      </div>
    </div>
    <div id="mesejTempah"></div>
  </div>

  <!-- ===== TAB 2: KALENDAR VIEW ===== -->
  <div id="view-kalendar" class="tab-view d-none">
    <div class="card shadow-sm border-0 rounded-4 mb-3">
      <div class="card-body">
        <h5 class="card-title mb-3 text-teal">Lihat Slot Ditempah</h5>
        <div class="mb-3">
          <label class="form-label">Bilik</label>
          <select class="form-select" id="kalendarBilik" onchange="muatKalendar()">
            <option value="">-- Sila Pilih --</option>
          </select>
        </div>
        <div id="kalendarSenarai"></div>
      </div>
    </div>
  </div>

  <!-- ===== TAB 3: DASHBOARD ADMIN ===== -->
  <div id="view-admin" class="tab-view d-none">
    <div class="card shadow-sm border-0 rounded-4 mb-3">
      <div class="card-body">
        <h5 class="card-title mb-3 text-teal">📄 Laporan Bulanan (PDF)</h5>
        <div class="row g-2 mb-2">
          <div class="col-6">
            <label class="form-label small mb-1">Bulan</label>
            <select class="form-select" id="laporanBulan"></select>
          </div>
          <div class="col-6">
            <label class="form-label small mb-1">Tahun</label>
            <select class="form-select" id="laporanTahun"></select>
          </div>
        </div>
        <div class="form-text mb-2">Laporan akan ikut penapis bilik di bawah (atau "Semua Bilik").</div>
        <button class="btn btn-teal w-100 rounded-pill py-2 fw-semibold" id="btnLaporan" onclick="janaLaporan()">
          📥 Muat Turun Laporan PDF
        </button>
      </div>
    </div>

    <div class="card shadow-sm border-0 rounded-4 mb-3">
      <div class="card-body">
        <h5 class="card-title mb-3 text-teal">Dashboard Admin</h5>
        <div class="mb-3">
          <label class="form-label">Tapis ikut Bilik</label>
          <select class="form-select" id="filterBilikAdmin" onchange="muatAdmin()">
            <option value="Semua">Semua Bilik</option>
          </select>
        </div>
        <div id="adminSenarai"></div>
      </div>
    </div>
  </div>

</div>

<!-- ===== TOAST ===== -->
<div class="toast-container position-fixed bottom-0 end-0 p-3">
  <div id="toastMesej" class="toast align-items-center text-white border-0" role="alert">
    <div class="d-flex">
      <div class="toast-body" id="toastBody">Mesej</div>
      <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
